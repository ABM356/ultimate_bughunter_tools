# Copy to .env and fill in real values. Never commit .env to git.

# PostgreSQL
POSTGRES_USER=hopeup
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=hopeup

# JWT signing key. Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_byte_hex

# AI provider keys (server-side only, never expose to frontend)
ANTHROPIC_API_KEY=sk-ant-xxxx
OPENAI_API_KEY=sk-xxxx

# Stripe billing
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Optional overrides
LOG_LEVEL=info
ENVIRONMENT=development
