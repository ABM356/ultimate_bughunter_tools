# ─────────────────────────────────────────────────────────────
# HopeUp Production Environment — DigitalOcean
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Container registry (DigitalOcean Container Registry or Docker Hub)
REGISTRY=registry.digitalocean.com/hopeup
VERSION=latest

# Database
POSTGRES_USER=hopeup
POSTGRES_PASSWORD=<generate-with-openssl-rand-base64-32>
POSTGRES_DB=hopeup_prod

# Redis
REDIS_PASSWORD=<generate-with-openssl-rand-base64-32>

# JWT
JWT_SECRET=<generate-with-openssl-rand-base64-64>

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Payments
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Optional: Notifications
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=

# Optional: Threat Intel
MISP_URL=
MISP_API_KEY=
ALIENVAULT_OTX_KEY=
